source "https://rubygems.org"

# Mirrors the GitHub Pages build environment so local == deployed.
gem "github-pages", group: :jekyll_plugins

# Theme + plugins used by the site
group :jekyll_plugins do
  gem "jekyll-remote-theme"
  gem "jekyll-include-cache"
  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-gist"
end

# Windows / JRuby friendliness
gem "tzinfo", ">= 1", "< 3"
gem "tzinfo-data", platforms: [:mingw, :x64_mingw, :mswin, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :x64_mingw, :mswin]
gem "webrick", "~> 1.8"
gem "csv"
gem "bigdecimal"
gem "base64"
gem "logger"
